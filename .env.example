# Shared infrastructure
DATABASE_URL="mysql://root:0000@localhost:3306/workwatch"
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET="replace-with-a-32-character-access-secret"
JWT_REFRESH_SECRET="replace-with-a-32-character-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
BCRYPT_ROUNDS=12

# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN="http://localhost:5173"
RETENTION_DAYS=30
DEFAULT_ALERT_SCORE_THRESHOLD=40
DEFAULT_ALERT_DURATION_MINUTES=15

# Client
VITE_API_URL="http://localhost:4000"
VITE_SOCKET_URL="http://localhost:4000"
# /public/models should include tiny face detector, face landmark 68, and face expression model files
VITE_FACE_MODEL_URL="/models"
